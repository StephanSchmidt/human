{
  "name": "human secure container",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/anthropics/devcontainer-features/claude-code:1": {},
    "ghcr.io/stephanschmidt/treehouse/human:1": {
      "proxy": true
    }
  },
  "runArgs": [
    "--add-host=host.docker.internal:host-gateway"
  ],
  "capAdd": [
    "NET_ADMIN"
  ],
  "forwardPorts": [
    19285,
    19286
  ],
  "remoteEnv": {
    "BROWSER": "human-browser",
    "HUMAN_CHROME_ADDR": "host.docker.internal:19286",
    "HUMAN_DAEMON_ADDR": "host.docker.internal:19285",
    "HUMAN_DAEMON_TOKEN": "${localEnv:HUMAN_DAEMON_TOKEN}",
    "HUMAN_PROXY_ADDR": "host.docker.internal:19287"
  },
  "postStartCommand": "sudo human-proxy-setup && human install --agent claude && human chrome-bridge"
}
